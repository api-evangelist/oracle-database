{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/CreateOAuthClientRequest",
  "title": "CreateOAuthClientRequest",
  "type": "object",
  "required": [
    "name",
    "grant_type"
  ],
  "properties": {
    "name": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "grant_type": {
      "type": "string",
      "enum": [
        "authorization_code",
        "client_credentials"
      ]
    },
    "redirect_uri": {
      "type": "string",
      "format": "uri"
    }
  }
}