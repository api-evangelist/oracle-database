{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/AlertList",
  "title": "AlertList",
  "type": "object",
  "properties": {
    "items": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "message_text": {
            "type": "string"
          },
          "message_level": {
            "type": "integer"
          },
          "originating_timestamp": {
            "type": "string",
            "format": "date-time"
          }
        }
      }
    }
  }
}