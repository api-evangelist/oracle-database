{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "#/components/schemas/SchedulerJob",
  "title": "SchedulerJob",
  "type": "object",
  "properties": {
    "owner": {
      "type": "string"
    },
    "job_name": {
      "type": "string"
    },
    "job_type": {
      "type": "string"
    },
    "state": {
      "type": "string"
    },
    "enabled": {
      "type": "boolean"
    },
    "next_run_date": {
      "type": "string",
      "format": "date-time"
    },
    "last_start_date": {
      "type": "string",
      "format": "date-time"
    },
    "repeat_interval": {
      "type": "string"
    }
  }
}